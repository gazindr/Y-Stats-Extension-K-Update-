{
    "manifest_version": 3,
    "name": "Y-Stats-Extension (Unofficial)",
    "version": "1.0.1",
    "description": "Неофициальное расширение для разработчиков Яндекс Игр. Показывает расширенную статистику",
    "author": "VyacheslavDeveloper",

    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "assets/icon-16.png",
            "48": "assets/icon-48.png",
            "128": "assets/icon-128.png"
        }
    },
    "icons": {
        "16": "assets/icon-16.png",
        "48": "assets/icon-48.png",
        "128": "assets/icon-128.png"
    },

    "content_scripts": [
        {
            "matches": ["https://games.yandex.ru/*"],
            "js": ["lib/chart.umd.js", "loader.js"],
            "css": ["styles.css"],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["src/*.js", "src/**/*.js"],
            "matches": ["https://games.yandex.ru/*"]
        }
    ],
    "host_permissions": [
        "https://games.yandex.ru/*",
        "https://raw.githubusercontent.com/*"
    ],
    "permissions": ["storage"]
}
